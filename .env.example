# PostgreSQL
POSTGRES_PASSWORD=changeme

# Server auth
MEMLAYER_AUTH_TOKEN=changeme

# Embeddings (OpenAI)
OPENAI_API_KEY=sk-...
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Embeddings (Ollama alternative)
# EMBEDDING_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# Large response file storage
# FILE_STORAGE_SOFT_LIMIT=0       # bytes, 0 = unlimited; eviction starts at this level
# FILE_STORAGE_HARD_LIMIT=0       # bytes, 0 = unlimited; sync eviction on write
# RESPONSE_BUDGET_BYTES=200000           # 200KB; responses over this use file-based flow
# EVICTION_INTERVAL_SECS=60

# Indexing (structural index + summary for large responses)
# INDEX_MODE=off                  # off | hybrid | llm-only
# INDEX_LLM_PROVIDER=             # openai | anthropic | ollama
# INDEX_LLM_MODEL=
# ANTHROPIC_API_KEY=
