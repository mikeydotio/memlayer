---
import Base from '../layouts/Base.astro';
---
<Base title="Download" description="Install Memlayer on your network or a VPS">
<main class="container" style="padding-top:48px;padding-bottom:60px">
  <h1 style="text-align:center;font-size:32px">Get Memlayer</h1>
  <p style="text-align:center;color:var(--text-dim);max-width:500px;margin:12px auto 40px">
    Choose your deployment path. No accounts needed — Memlayer is fully self-hosted.
  </p>

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-bottom:48px">
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:28px">
      <h3 style="margin-top:0">I'll host it on my network</h3>
      <p style="color:var(--text-dim);font-size:14px;margin-bottom:20px">
        Run Memlayer on a machine you control — home server, NAS, or development machine.
        Docker Compose gets you running in under 5 minutes.
      </p>
      <a href="/docs/getting-started" class="btn" style="width:100%;text-align:center;display:block">Self-Hosted Setup</a>
    </div>

    <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:28px">
      <h3 style="margin-top:0">Walk me through DigitalOcean</h3>
      <p style="color:var(--text-dim);font-size:14px;margin-bottom:20px">
        Step-by-step guide to deploying Memlayer on a DigitalOcean droplet.
        Interactive setup script handles credentials and networking.
      </p>
      <a href="/docs/digitalocean-setup" class="btn" style="width:100%;text-align:center;display:block">DigitalOcean Guide</a>
    </div>

    <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:28px">
      <h3 style="margin-top:0">I have a different VPS</h3>
      <p style="color:var(--text-dim);font-size:14px;margin-bottom:20px">
        Docker Compose instructions and environment variable reference.
        Works with any Linux VPS — Linode, Hetzner, Vultr, AWS EC2, etc.
      </p>
      <a href="/docs/vps-setup" class="btn btn-outline" style="width:100%;text-align:center;display:block">Generic VPS Guide</a>
    </div>
  </div>

  <h2 style="text-align:center;margin-top:0">Client Install</h2>
  <p style="text-align:center;color:var(--text-dim);margin-bottom:20px">
    Once your server is running, install the client on each machine with Claude Code:
  </p>
  <pre><code>curl -fsSL https://raw.githubusercontent.com/mikeydotio/memlayer/main/install.sh | bash</code></pre>
</main>
</Base>
